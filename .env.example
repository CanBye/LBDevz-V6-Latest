# Copy to .env and fill in real values. NEVER commit a populated .env.
# All secrets below must be provided via your host's secret manager in production.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=

# ─── MinIO / S3 ──────────────────────────────────────────────────────────────
MINIO_ENDPOINT=
MINIO_PORT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_USE_SSL=
S3_PUBLIC_URL=

# ─── Auth (NextAuth v5) ──────────────────────────────────────────────────────
# Prod: https://lbdevz.com   |   Dev: http://localhost:3000
NEXTAUTH_URL=
NEXTAUTH_SECRET=
# Discord OAuth redirect (portalda kayıtlı olmalı):
#   Prod: https://lbdevz.com/api/auth/callback/discord
#   Dev:  http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── License Service ─────────────────────────────────────────────────────────
LICENSE_API_URL=
# Host/scheme baked into protected plugins so the loader can reach this API.
# Prod: lbdevz.com   |   Dev: localhost
LICENSE_API_HOST=
# "http" (dev) or "https" (prod). Defaults to https when NODE_ENV=production.
LICENSE_API_SCHEME=
# Ed25519 keypair for anti-MITM license response signatures (base64 DER).
# Generate with:
#   node -e "const c=require('crypto');const{publicKey,privateKey}=c.generateKeyPairSync('ed25519');console.log('PRIV='+privateKey.export({type:'pkcs8',format:'der'}).toString('base64'));console.log('PUB='+publicKey.export({type:'spki',format:'der'}).toString('base64'))"
# PRIVATE stays only on the server; PUBLIC is baked into obfuscated plugins.
# Re-obfuscate versions after changing these so the new pubkey is embedded.
LICENSE_ED25519_PRIVATE_KEY=
LICENSE_ED25519_PUBLIC_KEY=
# Optional shared secret. If set, /api/v1/license/validate additionally requires
# the x-license-api-key header (extra gate for server-to-server callers).
LICENSE_VALIDATE_API_KEY=

# ─── Cloudflare Turnstile ────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Set to "1" to skip Turnstile ONLY in non-production local development.
TURNSTILE_DISABLE_IN_DEV=

# ─── IBAN / Ödeme ────────────────────────────────────────────────────────────
SITE_IBAN=
NEXT_PUBLIC_SITE_IBAN=

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ─── Internal ────────────────────────────────────────────────────────────────
# Must be "production" in production (controls Turnstile fail-closed, CSP, etc.)
NODE_ENV=
ADMIN_EMAILS=
