# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
# nested workspace node_modules (monorepo packages/apps)
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# turbo / monorepo build caches
.turbo/
**/dist/
**/.turbo/

# production
/build

# misc
.DS_Store
*.pem

# large binaries / installers (exceed GitHub 100MB limit; not project source)
*.exe
public/assets/icons/*.exe

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but allow the placeholder example (no real values) to be committed
!.env.example
!.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# private source code uploads (never serve publicly)
/private/source-codes/
